# Banco de dados (Supabase PostgreSQL - substituir pelo seu projeto)
DATABASE_URL=postgresql://postgres:[senha]@db.[project-id].supabase.co:5432/postgres

# Supabase
SUPABASE_URL=https://[project-id].supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# OpenAI (GPT + Whisper)
OPENAI_API_KEY=sk-...

# Digisac
DIGISAC_BASE_URL=https://contabilmadruga.digisac.me/api/v1
DIGISAC_BEARER_TOKEN=your-bearer-token

# Celery / Redis
REDIS_URL=redis://localhost:6379/0

# App
SECRET_KEY=your-secret-key-here
ENVIRONMENT=development
